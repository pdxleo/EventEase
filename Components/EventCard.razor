@using EventEase.Models

<article class="event-card">
    <h3 class="event-card__title">Event Card</h3>

    <EditForm EditContext="editContext" OnValidSubmit="HandleValidSubmit">
        <DataAnnotationsValidator />

        <div class="event-card__field">
            <label class="form-label">Event Name</label>
            <InputText class="form-control" @bind-Value="Event.Name" />
            <ValidationMessage For="() => Event.Name" />
        </div>

        <div class="event-card__field">
            <label class="form-label">Event Date</label>
            <InputDate class="form-control" @bind-Value="Event.Date" />
            <ValidationMessage For="() => Event.Date" />
        </div>

        <div class="event-card__field">
            <label class="form-label">Location</label>
            <InputText class="form-control" @bind-Value="Event.Location" />
            <ValidationMessage For="() => Event.Location" />
        </div>

        <p class="event-card__preview">
            <strong>Preview:</strong>
            @Event.Name on @Event.Date.ToString("dddd, MMM d, yyyy") in @Event.Location
        </p>

        @if (isSaved)
        {
            <p class="event-card__status">Event details are valid.</p>
        }

        <div class="event-actions">
            <button class="btn btn-success" type="submit">Save</button>
            <NavLink class="btn btn-primary" href="@($"events/{Event.Id}")">Details</NavLink>
            <NavLink class="btn btn-outline-primary" href="@($"events/{Event.Id}/register")">Register</NavLink>
        </div>
    </EditForm>
</article>

@code {
    [Parameter, EditorRequired]
    public EventItem Event { get; set; } = default!;

    private EditContext? editContext;
    private bool isSaved;

    protected override void OnParametersSet()
    {
        if (editContext is null || !ReferenceEquals(editContext.Model, Event))
        {
            editContext = new EditContext(Event);
            isSaved = false;
            editContext.OnFieldChanged += (_, _) => isSaved = false;
        }
    }

    private void HandleValidSubmit()
    {
        isSaved = true;
    }
}
