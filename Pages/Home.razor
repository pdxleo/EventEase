@page "/"
@page "/events"
@inject NavigationManager NavigationManager

<PageTitle>Browse Events</PageTitle>

<div class="mb-4 d-flex justify-content-between align-items-center">
	<div>
		<h1>Browse Events</h1>
		<p>Discover upcoming corporate and social events from EventEase.</p>
	</div>
	<button class="btn btn-primary" @onclick="@(() => NavigationManager.NavigateTo("/events/create"))">
		<span class="bi bi-plus-circle me-2"></span>Create Event
	</button>
</div>

<section class="event-grid">
	@foreach (var eventItem in events)
	{
		<EventCard Event="eventItem" />
	}
</section>

@code {
	private IReadOnlyList<EventItem> events = Array.Empty<EventItem>();

	protected override void OnInitialized()
	{
		events = EventRepository.GetAll();
	}
}
