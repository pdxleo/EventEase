@page "/events/{Id:int}/register"
@using System.ComponentModel.DataAnnotations
@using EventEase.Models
@inject EventEase.Services.AttendanceTracker AttendanceTracker
@inject EventEase.Services.StatePersistenceService PersistenceService
@inject EventEase.Services.UserSessionTracker SessionTracker

<PageTitle>Event Registration</PageTitle>

@if (eventItem is null)
{
    <h1>Event Not Found</h1>
    <p>The event you requested does not exist.</p>
    <NavLink class="btn btn-secondary" href="/events">Back to Events</NavLink>
}
else if (isSubmitted)
{
    <h1>Registration Confirmed</h1>
    <p>
        Thank you, @registration.Name. You are registered for <strong>@eventItem.Name</strong>
        on @eventItem.Date.ToString("MMMM d, yyyy") in @eventItem.Location.
    </p>
    <div class="alert alert-success" role="status">
        <strong>Attendance updated:</strong> @AttendanceTracker.GetRegistrationCount(eventItem.Id) registrations,
        @AttendanceTracker.GetAttendeeCount(eventItem.Id) attendees total.
    </div>
    <NavLink class="btn btn-primary" href="/events">Browse More Events</NavLink>
}
else
{
    <h1>Register for @eventItem.Name</h1>

    @if (SessionTracker.HasProfile)
    {
        <div class="alert alert-info" role="status">
            Returning session detected for <strong>@SessionTracker.UserName</strong>.
            Your contact details were pre-filled from session @SessionTracker.SessionId.
        </div>
    }

    <div class="card border-0 bg-light mb-4 shadow-sm">
        <div class="card-body">
            <h2 class="h5">Session Snapshot</h2>
            <p class="mb-1"><strong>Session:</strong> @SessionTracker.SessionId</p>
            <p class="mb-1"><strong>Previous registrations:</strong> @SessionTracker.RegistrationCount</p>
            <p class="mb-0"><strong>Current attendance:</strong> @AttendanceTracker.GetAttendeeCount(eventItem.Id) attendees</p>
        </div>
    </div>

    <EditForm Model="registration" OnValidSubmit="SubmitRegistration">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-3">
            <label class="form-label">Your Name</label>
            <InputText class="form-control" @bind-Value="registration.Name" />
            <ValidationMessage For="() => registration.Name" />
        </div>

        <div class="mb-3">
            <label class="form-label">Email</label>
            <InputText class="form-control" @bind-Value="registration.Email" />
            <ValidationMessage For="() => registration.Email" />
        </div>

        <div class="mb-3">
            <label class="form-label">Total Attendees</label>
            <InputNumber class="form-control" @bind-Value="registration.Attendees" />
            <ValidationMessage For="() => registration.Attendees" />
        </div>

        <div class="d-flex gap-2">
            <button class="btn btn-primary" type="submit">Submit Registration</button>
            <NavLink class="btn btn-outline-secondary" href="@($"/events/{eventItem.Id}")">Back to Details</NavLink>
        </div>
    </EditForm>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private EventItem? eventItem;
    private RegistrationForm registration = new();
    private bool isSubmitted;

    protected override void OnParametersSet()
    {
        eventItem = EventRepository.GetById(Id);
        registration = new RegistrationForm
        {
            Name = SessionTracker.UserName,
            Email = SessionTracker.Email,
            Attendees = 1
        };
        isSubmitted = false;
    }

    private async Task SubmitRegistration()
    {
        AttendanceTracker.Register(new EventRegistrationRecord
        {
            EventId = eventItem!.Id,
            EventName = eventItem.Name,
            AttendeeName = registration.Name,
            Email = registration.Email,
            GuestCount = registration.Attendees
        });

        SessionTracker.RecordRegistration(eventItem.Id, registration.Name, registration.Email);
        await PersistenceService.SaveAsync();
        isSubmitted = true;
    }

    private class RegistrationForm
    {
        [Required(ErrorMessage = "Name is required.")]
        [StringLength(80, ErrorMessage = "Name must be 80 characters or fewer.")]
        public string Name { get; set; } = string.Empty;

        [Required(ErrorMessage = "Email is required.")]
        [EmailAddress(ErrorMessage = "Please enter a valid email address.")]
        public string Email { get; set; } = string.Empty;

        [Range(1, 10, ErrorMessage = "Attendees must be between 1 and 10.")]
        public int Attendees { get; set; } = 1;
    }
}
